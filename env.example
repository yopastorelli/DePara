# DePara agent-oriented environment template
# Copy only required keys into .env or ~/.depara/config.env.

# HTTP
HOST=127.0.0.1
PORT=3000
NODE_ENV=production
MAX_PAYLOAD=100mb

# Runtime roots
DEPARA_RUNTIME_ROOT=/home/pi/.depara
# DEPARA_CONFIG_ENV_PATH=/home/pi/.depara/config.env
# DEPARA_DATA_DIR=/home/pi/.depara/data
# DEPARA_CONFIG_FILE=/home/pi/.depara/data/depara-config.json
# DEPARA_LOG_DIR=/home/pi/.depara/logs
# LOG_FILE=/home/pi/.depara/logs/app.log
# DEPARA_BACKUP_DIR=/home/pi/.depara/backups
# DEPARA_TEMP_DIR=/home/pi/.depara/temp
# DEPARA_RUNTIME_PUBLIC_DIR=/home/pi/.depara/public
# DEPARA_RELEASES_DIR=/home/pi/.depara/releases
# DEPARA_CURRENT_DIR=/home/pi/.depara/current

# Logging
LOG_LEVEL=warn
LOG_TO_CONSOLE=false
LOG_BUFFER_SIZE=10
LOG_FLUSH_INTERVAL=5000

# File operation safety
# If set, this replaces platform defaults.
# Linux/macOS delimiter is ":"; Windows delimiter is ";".
# Linux default when unset: homedir, tmpdir, /media, /mnt.
# Windows default when unset: homedir, C:\, D:\, E:\.
# DEPARA_ALLOWED_PATHS=/home/pi:/media:/mnt

# File operation performance
MAX_CONCURRENT_OPERATIONS=2
MAX_RECURSION_DEPTH=5
STREAM_HIGH_WATER_MARK=65536

# Rate limits
DEPARA_STRICT_RATE_LIMIT=20
DEPARA_NORMAL_RATE_LIMIT=300
DEPARA_READ_RATE_LIMIT=1000
DEPARA_SLIDESHOW_RATE_LIMIT=1000
# DEPARA_DISABLE_RATE_LIMITS=true

# Update/runtime operations
PM2_APP_NAME=DePara
DEPARA_ALLOW_SYSTEMD_FALLBACK=false
# DEPARA_UPDATE_SOURCE_ROOT=/home/pi/DePara
# DEPARA_DISABLE_UPDATE_SIDE_EFFECTS=true
# DEPARA_DISABLE_UPDATE_SCHEDULER=true
# DEPARA_DISABLE_PROCESS_HOOKS=true

# Launcher override
# DEPARA_APP_URL=http://127.0.0.1:3000

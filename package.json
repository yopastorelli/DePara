{
  "name": "depara",
  "version": "2.0.0",
  "description": "DePara - Gerenciador Automatizado de Arquivos com Slideshow de Imagens",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "start:bg": "pm2 start src/main.js --name DePara",
    "start:bg:prod": "pm2 start src/main.js --name DePara --env production",
    "stop:bg": "pm2 stop DePara",
    "restart:bg": "pm2 restart DePara",
    "status": "pm2 status",
    "logs": "pm2 logs DePara",
    "dev": "nodemon src/main.js",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand",
    "test:smoke": "jest --runInBand tests/smoke",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run test:unit && npm run test:e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "setup": "npm install",
    "setup:bg": "npm install && npm install -g pm2",
    "postinstall": "node -e \"console.log('✅ DePara instalado com sucesso! Use npm run start:bg para iniciar em segundo plano.')\""
  },
  "keywords": [
    "file-manager",
    "slideshow",
    "automation",
    "backup",
    "raspberry-pi",
    "nodejs",
    "express",
    "depara"
  ],
  "author": "yopastorelli",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "supertest": "^6.3.3",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

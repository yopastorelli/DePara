{
  "name": "depara",
  "version": "2.0.0",
  "description": "DePara - Gerenciador Automatizado de Arquivos com Slideshow de Imagens",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "start:bg": "pm2 start src/main.js --name DePara",
    "start:bg:prod": "pm2 start src/main.js --name DePara --env production",
    "stop:bg": "pm2 stop DePara",
    "restart:bg": "pm2 restart DePara",
    "status": "pm2 status",
    "logs": "pm2 logs DePara",
    "dev": "node --watch src/main.js",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand --forceExit",
    "test:smoke": "jest --runInBand tests/smoke --forceExit",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run test:unit && npm run test:e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "setup": "npm install",
    "setup:bg": "npm install && npm install -g pm2",
    "postinstall": "node -e \"console.log('✅ DePara instalado com sucesso! Use npm run start:bg para iniciar em segundo plano.')\""
  },
  "keywords": [
    "file-manager",
    "slideshow",
    "automation",
    "backup",
    "raspberry-pi",
    "nodejs",
    "express",
    "depara"
  ],
  "author": "yopastorelli",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "5.0.0"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
